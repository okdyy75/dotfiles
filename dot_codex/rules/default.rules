prefix_rule(pattern=["gh", "config", "set", "pager", "cat"], decision="allow")
prefix_rule(pattern=["gh", "pr", "view"], decision="allow")
prefix_rule(pattern=["gh", "pr", "diff"], decision="allow")
prefix_rule(pattern=["gh", "pr", "comment"], decision="allow")
prefix_rule(pattern=["gh", "pr", "create"], decision="allow")
prefix_rule(pattern=["git", "fetch"], decision="allow")
prefix_rule(pattern=["git", "checkout"], decision="allow")
prefix_rule(pattern=["git", "add"], decision="allow")
prefix_rule(pattern=["git", "commit"], decision="allow")
prefix_rule(pattern=["git", "push"], decision="allow")
prefix_rule(pattern=["direnv", "exec", ".", "yarn", "get-schema"], decision="allow")
prefix_rule(pattern=["direnv", "exec", ".", "yarn", "typecheck"], decision="allow")
prefix_rule(pattern=["docker", "compose", "exec"], decision="allow")
prefix_rule(pattern=["lefthook", "run", "pre-commit", "--all-files"], decision="allow")
prefix_rule(pattern=["codex", "exec"], decision="allow")
prefix_rule(pattern=["copilot", "--silent", "--no-ask-user", "--model", "gpt-5.4", "-p"], decision="allow")
