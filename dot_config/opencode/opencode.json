{
    "$schema": "https://opencode.ai/config.json",
    "permission": {
        "read": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "task": "allow",
        "skill": "allow",
        "lsp": "allow",
        "todowrite": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "external_directory": "ask",
        "doom_loop": "ask",
        "bash": {
            "git diff *": "allow",
            "git status *": "allow",
            "git show *": "allow",
            "git *": "ask",
            "gh pr list *": "allow",
            "gh pr view *": "allow",
            "gh pr edit *": "allow",
            "gh pr diff *": "allow",
            "direnv exec . yarn *": "allow",
            "docker compose *": "allow"
        },
        "serena_*": "allow",
        "playwright_*": "allow",
        "*": "ask"
    },
    "mcp": {
        "serena": {
            "type": "local",
            "command": [
                "uvx",
                "--from",
                "git+https://github.com/oraios/serena",
                "serena",
                "start-mcp-server",
                "--project",
                "$(pwd)"
            ],
            "enabled": true
        },
        "playwright": {
            "type": "local",
            "command": [
                "npx",
                "@playwright/mcp@latest"
            ],
            "enabled": true
        }
    }
}